# Cache static, content-hashed bundles aggressively — filenames change on every build
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon & social preview — safe to cache for a day
/favicon.svg
  Cache-Control: public, max-age=86400
/opengraph.jpg
  Cache-Control: public, max-age=86400

# APK download — let browsers cache for a day, revalidate after
/MR_ROBOT.apk
  Cache-Control: public, max-age=86400, must-revalidate
